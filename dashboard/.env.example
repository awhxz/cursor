# The spreadsheet ID is fixed in server config. The analytics tab uses gid=1654701914.
# An optional GID override is only needed to change the initially selected tab.
# GOOGLE_SHEET_GID=1654701914

# Optional fallback for a private sheet. Do not expose these values to the browser.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=dashboard-reader@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
